{
    "Logging": {
        "LogLevel": {
            "Default": "Debug",
            "System": "Information",
            "Microsoft": "Information"
        }
    },
	"ReverseProxy": {
		"Routes": {
			"route1": {
				"ClusterId": "conferencing",
				"AuthorizationPolicy": "VideoConferencingPolicy",
				"Match": {
					"Path": "conferencing/{**catch-all}"
				},
				"Transforms": [
					{
						"PathPattern": "{**catch-all}"
					}
				]
			}
		},
		"Clusters": {
			"conferencing": {
				"Destinations": {
					"destination1": {
						"Address": "http://localhost:5242/"
					}
				}
			}
		}
	}
}
